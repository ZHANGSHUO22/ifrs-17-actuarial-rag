# ==========================================
# ⚙️ 系统与环境配置
# ==========================================
.DS_Store
*.log
.env
.env.*

# ==========================================
# 🐍 Python 核心忽略项
# ==========================================
# 虚拟环境 (绝对不能传)
.venv/
venv/
env/
ENV/

# Python 编译缓存
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# ==========================================
# 🗄️ 关系型数据库 (防止泄露用户数据)
# ==========================================
*.db
*.sqlite
*.sqlite3
sql_app.db

# ==========================================
# 🧠 向量数据库 (防止上传数百 MB 的切片数据)
# ==========================================
chroma_db/
chroma_data/

# ==========================================
# 📂 动态文件与大模型 (防止触发 GitHub 100MB 限制)
# ==========================================
# 忽略临时上传的私密 PDF，但保留文件夹结构
backend/data/temp/*
!backend/data/temp/.gitkeep

# 忽略本地下载的 Embedding 大模型，但保留文件夹结构
backend/ml_models/*
!backend/ml_models/.gitkeep

# 原有的前端/旧版忽略 (保留)
node_modules/
build/
dist/
coverage/
files/*
!files/.gitkeep

# 注意：knowledge_base/public/ 里的官方 IFRS 规范文件没有在这里忽略，
# 因为它们是公共基础知识库，需要推送到 GitHub 以便服务器拉取。
