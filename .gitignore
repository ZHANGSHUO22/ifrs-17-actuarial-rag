# --- 你的原始配置 (通用/前端) ---
node_modules/
build/
dist/
coverage/
.DS_Store
*.log
.env*

# --- Python 必备忽略项 (⚠️ 非常重要) ---
# 虚拟环境 (绝对不能传)
.venv/
venv/
env/
ENV/

# Python 编译缓存
__pycache__/
*.py[cod]
*$py.class

# Pytest 测试缓存
.pytest_cache/

# --- IFRS 17 项目特定忽略项 ---
# 向量数据库本地存储 (如果不想传几百MB的数据)
chroma_db/
chroma_data/

# 上传的 PDF 文件 (如果是隐私数据，不要传)
# 如果你想保留 files 文件夹结构但忽略内容，可以这样写：
files/*
!files/.gitkeep
